---
import atomics from "../_atomics.css?raw";
const title = "AtiWindykacja — automatyczna windykacja należności dla InsERT";
const description =
  "AtiWindykacja automatycznie monitoruje należności i wysyła monity e-mail + SMS — prosto z Subiekt GT, nexo, Navireo lub Rewizor. Koniec ręcznego ścigania płatności.";
const canonical = "https://atiwindykacja.pl/";
const base = import.meta.env.BASE_URL; // '/atiwindykacja/' (lub '/' po podpięciu domeny)
const asset = (p) => (base.endsWith("/") ? base : base + "/") + p.replace(/^\//, "");
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="ATISOFT Sp. z o.o." />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={asset("favicon.svg")} type="image/svg+xml" />
    <link rel="icon" href={asset("favicon.ico")} sizes="any" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AtiWindykacja" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:image" content={asset("og.png")} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={asset("og.png")} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Base / tokeny z projektu Bold -->
    <style is:global>
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: #f7f4ed;
        font-family: "Inter", system-ui, sans-serif;
        color: #141414;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      a { color: #d62e27; text-decoration: none; }
      a:hover { color: #b02019; }
      ::selection { background: #ee3b34; color: #fff; }
      input { font-family: inherit; }
      @keyframes ati-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(1.5); }
      }
      @keyframes ati-float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-12px); }
      }
      @keyframes ati-toast {
        0% { opacity: 0; transform: translateY(14px) scale(0.95); }
        7%, 26% { opacity: 1; transform: translateY(0) scale(1); }
        34%, 100% { opacity: 0; transform: translateY(-10px) scale(0.98); }
      }
      .ati-dot { animation: ati-pulse 2s ease-in-out infinite; }
      .ati-float { animation: ati-float 5s ease-in-out infinite; }
      .hovlift {
        transition:
          transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
          box-shadow 0.3s ease;
      }
      .hovlift:hover { transform: translateY(-5px); }
      .navlink { color: #4a463e; transition: color 0.2s; }
      .navlink:hover { color: #141414; }
      .btn-press { transition: transform 0.2s ease, box-shadow 0.2s ease; }
      .btn-press:hover { transform: translateY(-2px); }
      .btn-press:active { transform: translateY(0); }

      /* Responsywność (siatka projektowa jest desktopowa) */
      @media (max-width: 900px) {
        [style*="grid-template-columns"] { grid-template-columns: 1fr !important; }
        #dc-root nav { display: none !important; }
      }
      @media (max-width: 620px) {
        [style*="padding: 64px 60px"] { padding: 36px 20px !important; }
        [style*="padding: 64px"] { padding: 36px 20px !important; }
        #top h1 { font-size: 42px !important; }
        h2 { font-size: 30px !important; }
      }
      @media (max-width: 420px) {
        #top h1 { font-size: 33px !important; }
      }
    </style>
    <style is:global set:html={atomics}></style>
  </head>
  <body>
    <slot />

    <script>
      // --- Kalkulator ROI (na żywo) ---
      const nums = Array.from(
        document.querySelectorAll<HTMLInputElement>('input[type="number"]'),
      );
      if (nums.length >= 3) {
        const grid = nums[0].parentElement?.parentElement;
        const resultBox = grid?.nextElementSibling;
        const spans = resultBox
          ? Array.from(resultBox.querySelectorAll<HTMLElement>(".sc-interp"))
          : [];
        const recalc = () => {
          const inv = parseFloat(nums[0].value) || 0;
          const pct = parseFloat(nums[1].value) || 0;
          const avg = parseFloat(nums[2].value) || 0;
          const overdueYear = inv * (pct / 100) * 12;
          const savings = Math.round(overdueYear * avg * 0.06);
          const hours = Math.round(overdueYear * 0.32);
          if (spans[0])
            spans[0].textContent = savings.toLocaleString("pl-PL");
          if (spans[1]) spans[1].textContent = String(hours);
        };
        nums.forEach((n) => n.addEventListener("input", recalc));
        recalc();
      }

      // --- Akordeon FAQ ---
      const faq = document.getElementById("faq");
      if (faq) {
        const buttons = Array.from(faq.querySelectorAll("button"));
        const items = buttons.map((btn) => {
          // chevron = OSTATNI bezpośredni <span> przycisku (nie wewnętrzny span z tekstem pytania)
          const directSpans = btn.querySelectorAll(":scope > span");
          return {
            btn,
            ans: btn.nextElementSibling as HTMLElement | null,
            chev: (directSpans[directSpans.length - 1] as HTMLElement) || null,
          };
        });
        const setState = (o: (typeof items)[number], open: boolean) => {
          if (o.ans) o.ans.style.display = open ? "block" : "none";
          if (o.chev) o.chev.textContent = open ? "–" : "+";
        };
        items.forEach((o, i) => {
          o.btn.style.cursor = "pointer";
          setState(o, i === 0);
          o.btn.addEventListener("click", () => {
            const isOpen = o.ans?.style.display !== "none";
            items.forEach((x) => setState(x, false));
            setState(o, !isOpen);
          });
        });
      }
    </script>
  </body>
</html>
